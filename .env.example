# ------------------------------------------------------------------
# Configuração do Dashboard Piquet
# Copia este ficheiro para `.env.local` e preenche os valores.
# ------------------------------------------------------------------

# URL base do backend Piquet (REST). Ex.: https://api.piquet.pt
# Deixa VAZIO para correr em modo de demonstração (dados mock locais).
NEXT_PUBLIC_API_URL=

# Atraso simulado (ms) das respostas em modo mock. Opcional.
NEXT_PUBLIC_MOCK_DELAY=300

# Backend REAL do Piquet app (Express partilhado com a app Flutter).
# Alimenta a aba "Reservas da app" (Serviços) com reservas/clientes reais.
NEXT_PUBLIC_PIQUET_API=http://localhost:3100

# Chave partilhada dos endpoints /admin/* do backend do Piquet app (tem de coincidir com PIQUET_ADMIN_KEY do backend)
NEXT_PUBLIC_PIQUET_ADMIN_KEY=dev-admin-key

# ---------------------------------------------------------------------------
# Supabase (Fase 0 — backend de produção). Cria o projeto em supabase.com,
# corre supabase/migrations/0001_init.sql no SQL Editor, e cola aqui as chaves
# (Project Settings → API). Depois: npm run seed.
# ---------------------------------------------------------------------------
# Servidor (Route Handlers) — NUNCA expor a service_role no browser:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Browser (auth) — chaves públicas:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Liga o frontend às Route Handlers reais (deixa vazio = modo mock/demo):
# NEXT_PUBLIC_API_URL=/api
